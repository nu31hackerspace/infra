lemmy.nu31.space {
        @lemmy_api path /api/* /pictrs/* /feeds/* /nodeinfo/* /.well-known/*
        @lemmy_activity header Accept *application/activity+json*
        @lemmy_ld header Accept *application/ld+json*
        @lemmy_post method POST

        handle @lemmy_api {
                reverse_proxy 10.10.10.2:8536 {
                        header_up X-Real-IP {remote_host}
                        header_up X-Forwarded-For {remote_host}
                        header_up X-Forwarded-Proto {scheme}
                        header_up Host {host}
                }
        }

        handle @lemmy_activity {
                reverse_proxy 10.10.10.2:8536 {
                        header_up X-Real-IP {remote_host}
                        header_up X-Forwarded-For {remote_host}
                        header_up X-Forwarded-Proto {scheme}
                        header_up Host {host}
                }
        }

        handle @lemmy_ld {
                reverse_proxy 10.10.10.2:8536 {
                        header_up X-Real-IP {remote_host}
                        header_up X-Forwarded-For {remote_host}
                        header_up X-Forwarded-Proto {scheme}
                        header_up Host {host}
                }
        }

        handle @lemmy_post {
                reverse_proxy 10.10.10.2:8536 {
                        header_up X-Real-IP {remote_host}
                        header_up X-Forwarded-For {remote_host}
                        header_up X-Forwarded-Proto {scheme}
                        header_up Host {host}
                }
        }

        handle {
                reverse_proxy 10.10.10.2:1234
        }
}

a.lemmy.nu31.space {
        reverse_proxy 10.10.10.2:3000
}

zulip.nu31.space {
        reverse_proxy https://10.10.10.2:443 {
                transport http {
                        tls_insecure_skip_verify
                }
                header_up X-Real-IP {remote_host}
                header_up X-Forwarded-For {remote_host}
                header_up X-Forwarded-Proto {scheme}
                header_up Host {host}
        }
}

mqtt.nu31.space {
        # Caddy obtains and renews the TLS cert for this domain.
        # The cert is read by the MQTT container from the shared caddy-data volume.
        # MQTT clients connect directly on port 8883 (MQTTS), not through Caddy.
        respond "MQTT broker — connect on port 8883 via MQTTS" 200
}
