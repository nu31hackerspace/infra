{
        email vovochkastelmashchuk@gmail.com
        storage file_system {
                root /caddy_storage/
        }
}

(maintenance) {
	handle {
		root * /etc/caddy
		rewrite * /maintenance.html
		file_server
	}
}

maintenance.nu31.space {
	import maintenance
}

nu31.space {
        reverse_proxy * nu31space_app:3000
}

grafana.nu31.space {
        reverse_proxy * infra_grafana:3000
}

prismo.nu31.space {
        reverse_proxy * prismo_app:3000
}

compass.nu31.space {
        reverse_proxy * infra_mongo-rs-viewer:8080
}

pgweb.nu31.space {
        reverse_proxy * infra_pgweb-oauth-proxy:4180
}

wiki.nu31.space {
        reverse_proxy * infra_wikijs:3000
}

events.nu31.space {
        reverse_proxy * gancio_app:13120
}

forum.nu31.space {
        @lemmy_api path /api/* /pictrs/* /feeds/* /nodeinfo/* /.well-known/*
        @lemmy_activity header Accept *application/activity+json*
        @lemmy_ld header Accept *application/ld+json*
        @lemmy_post method POST

        handle @lemmy_api {
                reverse_proxy 10.10.10.2:8536
        }

        handle @lemmy_activity {
                reverse_proxy 10.10.10.2:8536
        }

        handle @lemmy_ld {
                reverse_proxy 10.10.10.2:8536
        }

        handle @lemmy_post {
                reverse_proxy 10.10.10.2:8536
        }

        handle {
                reverse_proxy 10.10.10.2:1234
        }
}

mqtt.nu31.space {
        # Caddy obtains and renews the TLS cert for this domain.
        # The cert is read by the MQTT container from the shared caddy-data volume.
        # MQTT clients connect directly on port 8883 (MQTTS), not through Caddy.
        respond "MQTT broker — connect on port 8883 via MQTTS" 200
}
