{
        email vovochkastelmashchuk@gmail.com
        storage file_system {
                root /caddy_storage/
        }
}

(maintenance) {
	handle {
		root * /etc/caddy
		rewrite * /maintenance.html
		file_server
	}
}

maintenance.nu31.space {
	import maintenance
}

nu31.space {
        @matrix_wellknown path /.well-known/matrix/*
        handle @matrix_wellknown {
                reverse_proxy matrix.nu31.space {
                        header_up X-Real-IP {remote_host}
                        header_up X-Forwarded-For {remote_host}
                        header_up X-Forwarded-Port {http.request.port}
                        header_up X-Forwarded-TlsProto {tls_protocol}
                        header_up X-Forwarded-TlsCipher {tls_cipher}
                        header_up X-Forwarded-HttpsProto {proto}
                        header_up X-Forwarded-Proto {scheme}
                        header_up Host matrix.nu31.space
                }
        }
        handle {
                reverse_proxy * nu31space_app:3000
        }
}

grafana.nu31.space {
        reverse_proxy * infra_grafana:3000
}

compass.nu31.space {
        reverse_proxy * infra_mongo-rs-viewer:8080
}

pgweb.nu31.space {
        reverse_proxy * postgres-viewer:80
}

wiki.nu31.space {
        reverse_proxy * infra_wikijs:3000
}

events.gc.nu31.space {
        reverse_proxy * gancio_app:13120
}


prismo.gc.nu31.space {
        reverse_proxy * prismo_app:3000
}

mqtt.gc.nu31.space {
        # Caddy obtains and renews the TLS cert for this domain.
        # The cert is read by the MQTT container from the shared caddy-data volume.
        # MQTT clients connect directly on port 8883 (MQTTS), not through Caddy.
        respond "MQTT broker — connect on port 8883 via MQTTS" 200
}
