# ── MQTT broker ───────────────────
# Admin user is seeded from USERNAME + PASSWORD (shared credentials, same as mongo/postgres).
# MQTT_PORT is the plain listener used internally on mqtt-net only (not published externally).
# MQTT_TLS_PORT is published externally; IoT devices connect via mqtts://MQTT_TLS_DOMAIN:8883.
# Caddy provisions the TLS cert for MQTT_TLS_DOMAIN and stores it in the caddy-data volume.
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_TLS_DOMAIN=mqtt.nu31.space
